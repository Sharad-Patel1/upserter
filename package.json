{
  "name": "upserter",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "auth:user:add": "bun run src/scripts/create-auth-user.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.4",
    "@inquirer/prompts": "^8.3.0",
    "@t3-oss/env-core": "^0.13.10",
    "better-auth": "^1.5.4",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "elysia": "latest",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.9.3"
  },
  "module": "src/index.js"
}
